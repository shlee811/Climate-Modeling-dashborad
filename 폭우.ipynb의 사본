 적용하는 것이 정석입니다)\n","X_train, X_test, y_train, y_test = train_test_split(\n","    X, y, test_size=0.2, stratify=y, random_state=42\n",")\n","\n","# 3. SMOTE 적용 (학습 데이터의 불균형 해결)\n","# 검증 데이터(X_test)에는 절대 적용하면 안 됩니다!\n","smote = SMOTE(sampling_strategy=0.5,random_state=42)\n","X_train_over, y_train_over = smote.fit_resample(X_train, y_train)\n","\n","print(f\"SMOTE 적용 전 학습 데이터 폭우(1) 개수: {sum(y_train == 1)}\")\n","print(f\"SMOTE 적용 후 학습 데이터 폭우(1) 개수: {sum(y_train_over == 1)}\")\n","\n","# 4. XGBoost 모델 학습 (SMOTE를 썼으므로 scale_pos_weight는 1로 두거나 작게 조정합니다)\n","model_smote = XGBClassifier(\n","    n_estimators=200,\n","    max_depth=6,\n","    learning_rate=0.1,\n","    random_state=42,\n","    eval_metric='logloss'\n",")\n","\n","model_smote.fit(X_train_over, y_train_over)\n","\n","# 5. 2025년 데이터(test)에 적용 및 임계값 0.8 설정\n","X_2025 = test[features]\n","y_probs_2025 = model_smote.predict_proba(X_2025)[:, 1]\n","\n","# 임계값 0.8 적용\n","threshold = 0.3\n","test['예측_결과_SMOTE'] = (y_probs_2025 >= threshold).astype(int)\n","\n","# 6. 성적표 확인 (사용자님이 만든 미래 3시간 레이블 기준)\n","print(\"\\n--- SMOTE 적용 모델 2025년 예보 성적표 (임계값 0.8) ---\")\n","print(classification_report(test['실제_폭우_여부'], test['예측_결과_SMOTE']))"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"LBOv8nPI0MvW","executionInfo":{"status":"ok","timestamp":1774590575562,"user_tz":-540,"elapsed":2179,"user":{"displayName":"구본경","userId":"02942675838900099954"}},"outputId":"3322f127-af17-4b99-e363-0e7b7d6bb4be"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["SMOTE 적용 전 학습 데이터 폭우(1) 개수: 1158\n","SMOTE 적용 후 학습 데이터 폭우(1) 개수: 69356\n","\n","--- SMOTE 적용 모델 2025년 예보 성적표 (임계값 0.8) ---\n","              precision    recall  f1-score   support\n","\n","           0       0.99      0.97      0.98      2851\n","           1       0.27      0.61      0.37        51\n","\n","    accuracy                           0.96      2902\n","   macro avg       0.63      0.79      0.68      2902\n","weighted avg