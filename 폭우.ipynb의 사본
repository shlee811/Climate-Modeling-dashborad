앞뒤 12시간 추출 가능!\n","    start_time = storm_sample - pd.Timedelta(hours=12)\n","    end_time = storm_sample + pd.Timedelta(hours=12)\n","\n","    # 해당 구간 데이터 추출 (원본 df에서 가져와야 앞뒤 상황이 보임)\n","    sample_period = gangnam.loc[start_time:end_time]\n","\n","    plt.figure(figsize=(12, 6))\n","    plt.plot(sample_period.index, sample_period['습도'], label='습도(%)', marker='o', color='blue')\n","    plt.plot(sample_period.index, sample_period['3시간강수량'], label='3시간누적강수(mm)', marker='s', color='red')\n","    plt.axvline(storm_sample, color='orange', linestyle='--', linewidth=2, label='폭우 징후 시점')\n","    plt.title(f'폭우 사례 시계열 분석 (원본 데이터 기반)')\n","    plt.legend()\n","    plt.grid(True)\n","    plt.show()"],"metadata":{"id":"9KL4ULwLr4ta","colab":{"base_uri":"https://localhost:8080/","height":548},"executionInfo":{"status":"ok","timestamp":1774789690892,"user_tz":-540,"elapsed":519,"user":{"displayName":"구본경","userId":"02942675838900099954"}},"outputId":"5cfe2a01-6f5f-413d-e049-68da9843700f"},"execution_count":null,"outputs":[{"output_type":"display_data","data":{"text/plain":["<Figure size 1200x600 with 1 Axes>"],"image/png":"\n"},"metadata":{}}]},{"cell_type":"markdown","source":["1. 시계열 추세 (Time-Series) 분석\n","\n","결과: 폭우가 쏟아지기 전, 습도가 급상승하는 패턴이 뚜렷하게 나온다. 하지만 기압의 차이가 폭우의 징후라고 보일만큼의 뚜렷한 감소패턴이 보이지않아 변수의 선택에 생각해볼필요가있다.\n","\n","인사이트: 습도가 100%에 가까워질수록 실제 폭우가 발생할 확률이 비례해서 높아지는 양상을 보인다. 이는 습도가 폭우의 매우 강력한 선행 지표임을 의미한다.\n","\n","2. Box Plot\n","\n","결과: 비가 오지 않는 평시(Label 0)에는 습도 분포가 매우 넓고 다양하게 나타납니다.\n","\n","인사이트: 반면, 폭우 징후 시점(Label 1)에는 습도가 100% 근처에 극단적으로 밀집되는 특징을 보입니다. 즉, 고습도 상태는 폭우 예측을 위한 필수적인 분류 기준입니다.\n","\n","3. Heatmap\n","\n","분석 결과: '3시간 기온변화'와 '습도변화'의 상관계수는 -0.88로 매우 높게 나타났습니다.\n","\n","인사이트: 이는 기온이 떨어지면 습도가 오르는 기상학적 인과관계를 잘 보여주며, 모델링 과정에서 다중공선성 발생 여부를 체크해야 할 핵심 포인트입니다. 또한, 폭우와 가장 밀접한 상관관계를 가진 변수는 3시간 누적 강수량(0.58)으로 확인되었습니다.\n","\n","4. 종합 결론\n","\n","집중호우는 '습도'와 '3시간 누적 강수량' 지표에 가장 민감하게 반응합니다. 특히 대기 중 습도가 포화 상태(100% 근접)에 도달하는 시점에는 폭우가 발생할 확률이 비약적으로 상승하므로, 이를 모델의 핵심 판단 근거로 활용할 수 있습니다."],"metadata":{"id":"3eIq3dtJ-Ad0"}},{"cell_type":"markdown","source":["XGBOOST"],"metadata":{"id":"O1n3l1Aj11h0"}},{"cell_type":"code","source":["from sklearn.model_selection import train_test_split\n","from xgboost import XGBClassifier\n","from sklearn.metrics import classification_report, confusion_matrix\n","import numpy as np\n","\n","# 1. 사용할 피처 선정 (온도차이와 moist_energy는 미리 계산되어 있어야 합니다!)\n","# 만약 계산 안 하셨다면 아래 주석 해제 후 실행\n","df['온도차이'] = df['기온'] - df['이슬점']\n","df['moist_energy'] = (df['기온'] * df['습도']) / 100\n","\n","features = [\n","    'region','강수량', '습도', '3시간강수량', '3시간기온변화',\n","    '3시간습도변화', '이슬점', '온도차이', 'moist_energy'\n","]\n","\n","X = df[features]\n","y = df['label']\n","\n","# 2. 학습(80%) 및 검증(20%) 데이터 분리\n","# stratify=y는 폭우(1) 데이터 비중을 양쪽에 똑같이 맞춰줍니다.\n","X_train, X_test, y_train, y_test = train_test_split(\n","    X, y, test_size=0.2, stratify=y, random_state=42\n",")\n","\n","# 3. 데이터 불균형 가중치 계산 (매우 중요!)\n","# 정상(0) 개수 / 폭우(1) 개수\n","ratio = len(y_train[y_train==0]) / len(y_train[y_train==1])\n","\n","# 4. XGBoost 모델 생성 및 학습\n","model = XGBClassifier(\n","    n_estimators=200,      # 데이터가 많으므로 조금 더 많이 학습\n","    max_depth=6,           # 복잡한 패턴 학습을 위해 깊이 조정\n","    learning_rate=0.1,\n","    scale_pos_weight=ratio, # 불균형 해결사\n","    random_state=42,\n","    use_label_encoder=False,\n","    eval_metric='logloss'\n",")\n","\n","print(\"학습 시작 중... 잠시만 기다려 주세요.\")\n","model.fit(X_train, y_train)\n","\n","# 5. 결과 확인\n","y_pred = model.predict(X_test)\n","print(\"\\n--- 서울 통합 모델 검증 결과 ---\")\n","print(classification_report(y_test, y_pred))"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"q1hGw2tFujY8","executionInfo":{"status":"ok","timestamp":1774793168428,"user_tz":-540,"elapsed":9155,"user":{"displayName":"구본경","userId":"02942675838900099954"}},"outputId":"451c7294-4338-4443-cf88-38b0f65431a3"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["학습 시작 중... 잠시만 기다려 주세요.\n","\n","--- 서울 통합 모델 검증 결과 ---\n","              precision    recall  f1-score   support\n","\n","           0       1.00      0.99      0.99     34681\n","           1       0.39      0.96      0.56       289\n","\n","    accuracy                           0.99     34970\n","   macro avg       0.70      0.97      0.78     34970\n","weighted avg       0.99      0.99      0.99     34970\n","\n"]}]},{"cell_type":"code","source":["# 1. 폭우(1)일 확률 가져오기\n","y_probs = model.predict_proba(X_test)[:, 1]\n","\n","# 2. 임계값을 0.5가 아니라 조금 더 높여서 테스트 (예: 0.7 또는 0.8)\n","# 이 수치를 높일수록 Precision은 올라가고 Recall은 내려갑니다.\n","threshold = 0.8\n","y_pred_balanced = (y_probs >= threshold).astype(int)\n","\n","print(f\"--- 임계값 {threshold} 적용 결과 ---\")\n","print(classification_report(y_test, y_pred_balanced))"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"zXBvQktQvoP6","executionInfo":{"status":"ok","timestamp":1774791017801,"user_tz":-540,"elapsed":174,"user":{"displayName":"구본경","userId":"02942675838900099954"}},"outputId":"496a0845-7c60-4219-a437-dbc7ecb2fb2b"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["--- 임계값 0.8 적용 결과 ---\n","              precision    recall  f1-score   support\n","\n","           0       1.00      0.99      1.00     34681\n","           1       0.54      0.90      0.68       289\n","\n","    accuracy                           0.99     34970\n","   macro avg       0.77      0.94      0.84     34970\n","weighted avg       1.00      0.99      0.99     34970\n","\n"]}]},{"cell_type":"markdown","source":["랜덤포레스트"],"metadata":{"id":"DPrNmGDwzbh4"}},{"cell_type":"code","source":["from sklearn.ensemble import RandomForestClassifier\n","from sklearn.model_selection import train_test_split\n","from sklearn.metrics import classification_report, confusion_matrix\n","\n","# 1. 데이터 분할 (XGBoost와 동일한 조건으로 비교하기 위해 같은 random_state 권장)\n","X = df[features]\n","y = df['label']\n","\n","X_train, X_test, y_train, y_test = train_test_split(\n","    X, y, test