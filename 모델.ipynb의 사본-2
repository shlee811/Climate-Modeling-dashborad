om_state=42,\n","        eval_metric='aucpr'\n","    )\n","    temp_model.fit(X_train_smote, y_train_smote,eval_set=[(X_valid, y_valid)], verbose=False)\n","\n","    # 해당 모델의 확률값 예측\n","    probs = temp_model.predict_proba(X_valid)[:, 1]\n","\n","    for t in thresholds:\n","        preds = (probs >= t).astype(int)\n","        p = precision_score(y_valid, preds, zero_division=0)\n","        r = recall_score(y_valid, preds, zero_division=0)\n","        f1 = f1_score(y_valid, preds, zero_division=0)\n","\n","        results.append({\n","            'Weight': w,\n","            'Threshold': t,\n","            'Precision': p,\n","            'Recall': r,\n","            'F1': f1\n","        })\n","\n","# 2. 결과 출력 (데이터프레임 형태)\n","df_res = pd.DataFrame(results)\n","print(\"\\n--- [최적 조합 탐색 결과] ---\")\n","print(df_res.sort_values(by='F1', ascending=False).head(10))"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"6sUjJDd22Hxb","executionInfo":{"status":"ok","timestamp":1775480644094,"user_tz":-540,"elapsed":655908,"user":{"displayName":"구본경","userId":"02942675838900099954"}},"outputId":"b3a7ed4a-9c9d-4013-d82f-35e7e9c0c140"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["현재 가중치 1로 학습 중...\n","현재 가중치 10로 학습 중...\n","현재 가중치 25로 학습 중...\n","현재 가중치 50로 학습 중...\n","현재 가중치 100로 학습 중...\n","\n","--- [최적 조합 탐색 결과] ---\n","    Weight  Threshold  Precision    Recall        F1\n","8       25        0.3   0.253579  0.230912  0.241715\n","17     100        0.5   0.261851  0.216015  0.236735\n","9       25        0.5   0.285714  0.197393  0.233480\n","16     100        0.3   0.216612  0.247672  0.231103\n","18     100        0.7   0.303951  0.186220  0.230947\n","13      50        0.5   0.255981  0.199255  0.224084\n","4       10        0.3   0.242291  0.204842  0.221998\n","10      25        0.7   0.328467  0.167598  0.221948\n","0        1        0.3   0.313993  0.171322  0.221687\n","12      50        0.3   0.215686  0.225326  0.220401\n"]}]},{"cell_type":"code","source":["# 1. 가장 좋았던 설정으로 모델 재학습 (Train + Valid 합쳐서 학습하면 더 좋지만, 일단 Train으로만)\n","final_model = XGBClassifier(\n","    n_estimators=1000,\n","    learning_rate=0.05,\n","    scale_pos_weight=10, # 우리가 찾은 최적 가중치\n","    tree_method='hist',\n","    enable_categorical=True,\n","    early_stopping_rounds=50,\n","    random_state=42\n",")\n","\n","final_model.fit(X_train_smote, y_train_smote,eval_set=[(X_valid, y_valid)], verbose=False)\n","\n","# 2. 드디어 처음 꺼내는 [Test 데이터 (2025년)] 예측\n","test_probs = final_model.predict_proba(X_test)[:, 1]\n","\n","# 3. 우리가 찾은 최적 임계값 0.7 적용\n","final_test_preds = (test_probs >= 0.7).astype(int)\n","\n","# 4. 최종 성적표 출력\n","from sklearn.metrics import classification_report, confusion_matrix, average_precision_score\n","\n","print(\"--- [최종 2025년 실전 Test 데이터 성적표] ---\")\n","print(classification_report(y_test, final_test_preds))\n","print(\"\\n최종 Test PR-AUC:\", average_precision_score(y_test, test_probs))\n","\n","# 혼동 행렬로 실제 몇 개 맞혔는지 확인\n","print(\"\\nConfusion Matrix:\")\n","print(confusion_matrix(y_test, final_test_preds))"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"Rvx24SBt2p7J","executionInfo":{"status":"ok","timestamp":1775482153105,"user_tz":-540,"elapsed":190268,"user":{"displayName":"구본경","userId":"02942675838900099954"}},"outputId":"dcbf3788-2367-4060-bcb8-b961fcac6c28"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["--- [최종 2025년 실전 Test 데이터 성적표] ---\n","              precision    recall  f1-score   support\n","\n","           0       1.00      1.00      1.00    208596\n","           1       0.19      0.07      0.10       723\n","\n","    accuracy                           1.00    209319\n","   macro avg       0.59      0.53      0.55    209319\n","weighted avg       0.99      1.00      0.99    209319\n","\n","\n","최종 Test PR-AUC: 0.06580333105849143\n","\n","Confusion Matrix:\n","[[208391    205]\n"," [   675     48]]\n"]}]},{"cell_type":